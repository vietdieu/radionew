# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_API_KEY2=
GEMINI_API_KEY3=
GEMINI_API_KEY4=
GEMINI_API_KEY5=
GEMINI_API_KEY6=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GROQ API Key option
# Used to offload summarization and text generation processing to Groq Cloud API
GROQ_API_KEY=

# Google Cloud Storage Configuration for Podcasts
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=
GCS_PRIVATE_KEY=
GCS_CLIENT_EMAIL=
CLOUD_STORAGE_PUBLIC_URL=https://storage.googleapis.com

# Supabase Storage Configuration for Podcasts (Bucket name used: "podcast-audio" - must be public with custom RLS policy)
SUPABASE_URL=https://omcuhthpeenwlzdwzlra.supabase.co
SUPABASE_ANON_KEY=sb_publishable_jYhv4P78VyLfdsAEa70Mlw_T3vzR6Ez


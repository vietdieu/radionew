{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:client": "vite",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --external:express --external:cors --external:dotenv --external:@google/genai --external:vite --external:@google-cloud/storage --external:@google-cloud/text-to-speech --external:uuid --external:xml2js --external:@supabase/supabase-js --external:ws --external:fsevents --sourcemap --outfile=server.js",
    "start": "node server.js",
    "clean": "rm -rf dist server.js server.cjs server.js.map server.cjs.map",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@google-cloud/text-to-speech": "^6.4.1",
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "edge-tts": "^1.0.1",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "uuid": "^14.0.1",
    "vite": "^6.2.3",
    "xml2js": "^0.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14"
  },
  "allowScripts": {
    "@google/genai@2.9.0": true,
    "protobufjs@7.6.4": true,
    "esbuild@0.25.12": true
  },
  "overrides": {
    "uuid": "$uuid"
  }
}
